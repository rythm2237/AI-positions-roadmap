0:{"rsc":["$","$1","c",{"children":[["$","$L2",null,{"roadmap":{"id":"2","slug":"prompt-engineer","title":"Prompt Engineer","description":"Design, test, evaluate, and manage prompts for reliable language-model applications and business workflows.","category":"Prompting","level":"Beginner to Intermediate","duration":"12 weeks","status":"mvp-ready","totalEstimatedHours":70,"phases":[{"id":"prompt-p1","phaseNumber":1,"title":"Language Model Fundamentals","description":"Learn how LLMs tokenize, attend to context, sample outputs, and follow prompt hierarchy.","estimatedDuration":"2 weeks","weekRange":"Week 1-2","outcome":"You can explain and improve prompts using model behavior instead of guesswork.","access":"free","sections":[{"id":"prompt-p1-s1","title":"How Large Language Models Work","description":"Understand tokenization, attention, next-token prediction, and context windows.","estimatedTime":"4 hours","difficulty":"Beginner","learningTypes":["Video","Reading"],"resources":[{"label":"Andrej Karpathy: Let's build GPT","type":"video","url":"https://www.youtube.com/watch?v=kCc8FmEb1nY"},{"label":"The Illustrated Transformer","type":"article","url":"https://jalammar.github.io/illustrated-transformer/"}],"test":{"id":"prompt-p1-s1-test","title":"How Large Language Models Work Check","questions":[{"id":"prompt-p1-s1-q1","question":"What is a token in an LLM?","options":["A unit of text processed by the model","A database password","A training GPU","A web request header"],"correctAnswerIndex":0,"explanation":"Models process text as tokens, which can be words, subwords, or characters."},{"id":"prompt-p1-s1-q2","question":"What does the attention mechanism help a transformer do?","options":["Relate tokens to other tokens in the context","Compress images only","Store API credentials","Disable sampling"],"correctAnswerIndex":0,"explanation":"Attention lets tokens weigh relevant parts of the context."},{"id":"prompt-p1-s1-q3","question":"Which validation step is most appropriate for How Large Language Models Work?","options":["Accepting the first AI or automation output without checking it","Comparing the output with source data, tool logs, and task-specific requirements","Deleting input examples after every run","Changing multiple variables before each test run"],"correctAnswerIndex":1,"explanation":"Reliable AI and automation work requires validating outputs against source data, execution logs, and task requirements."}]}},{"id":"prompt-p1-s2","title":"The Anatomy of a Great Prompt","description":"Use role, task, context, constraints, examples, and output formats.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"OpenAI Prompt Engineering Guide","type":"article","url":"https://platform.openai.com/docs/guides/prompt-engineering"},{"label":"Learn Prompting","type":"article","url":"https://learnprompting.org/docs/introduction"}],"test":{"id":"prompt-p1-s2-test","title":"The Anatomy of a Great Prompt Check","questions":[{"id":"prompt-p1-s2-q1","question":"Which prompt element most directly controls the response schema?","options":["Output format instructions","Browser zoom","Model provider logo","Conversation title"],"correctAnswerIndex":0,"explanation":"Explicit schema instructions reduce ambiguity."},{"id":"prompt-p1-s2-q2","question":"Why include constraints in a prompt?","options":["To limit acceptable behavior and outputs","To increase billing automatically","To make tokenization impossible","To remove context"],"correctAnswerIndex":0,"explanation":"Constraints define boundaries such as length, tone, sources, and forbidden actions."},{"id":"prompt-p1-s2-q3","question":"Which validation step is most appropriate for The Anatomy of a Great Prompt?","options":["Accepting the first AI or automation output without checking it","Comparing the output with source data, tool logs, and task-specific requirements","Deleting input examples after every run","Changing multiple variables before each test run"],"correctAnswerIndex":1,"explanation":"Reliable AI and automation work requires validating outputs against source data, execution logs, and task requirements."}]}},{"id":"prompt-p1-s3","title":"Temperature, Top-P & Sampling","description":"Learn how sampling controls creativity, determinism, and risk.","estimatedTime":"3 hours","difficulty":"Intermediate","learningTypes":["Reading","Quiz"],"resources":[{"label":"Hugging Face Generation Strategies","type":"article","url":"https://huggingface.co/docs/transformers/en/generation_strategies"},{"label":"OpenAI Text Generation Guide","type":"article","url":"https://platform.openai.com/docs/guides/text-generation"}],"test":{"id":"prompt-p1-s3-test","title":"Temperature, Top-P & Sampling Check","questions":[{"id":"prompt-p1-s3-q1","question":"What does temperature close to 0 usually produce?","options":["More deterministic outputs","Longer context windows","More API keys","Guaranteed factuality"],"correctAnswerIndex":0,"explanation":"Lower temperature reduces randomness but does not guarantee truth."},{"id":"prompt-p1-s3-q2","question":"When is a higher temperature usually more appropriate?","options":["Brainstorming varied creative options","Extracting exact invoice totals","Running database migrations","Validating legal citations"],"correctAnswerIndex":0,"explanation":"Creative tasks benefit from more diverse sampling."},{"id":"prompt-p1-s3-q3","question":"Which validation step is most appropriate for Temperature, Top-P & Sampling?","options":["Accepting the first AI or automation output without checking it","Comparing the output with source data, tool logs, and task-specific requirements","Deleting input examples after every run","Changing multiple variables before each test run"],"correctAnswerIndex":1,"explanation":"Reliable AI and automation work requires validating outputs against source data, execution logs, and task requirements."}]}},{"id":"prompt-p1-s4","title":"System Prompts & Personas","description":"Use higher-priority instructions while keeping personas safe and task-specific.","estimatedTime":"3 hours","difficulty":"Intermediate","learningTypes":["Reading","Practice"],"resources":[{"label":"Anthropic Prompt Engineering Overview","type":"article","url":"https://docs.anthropic.com/en/docs/build-with-claude/prompt-engineering/overview"},{"label":"OpenAI Prompt Engineering Guide","type":"article","url":"https://platform.openai.com/docs/guides/prompt-engineering"}],"test":{"id":"prompt-p1-s4-test","title":"System Prompts & Personas Check","questions":[{"id":"prompt-p1-s4-q1","question":"How does a system message differ from a user message?","options":["It sets higher-priority behavior for the assistant","It always contains JSON","It is ignored by model APIs","It stores billing settings"],"correctAnswerIndex":0,"explanation":"System instructions are used to define assistant behavior and constraints."},{"id":"prompt-p1-s4-q2","question":"What is a risk of an overly broad persona prompt?","options":["Inconsistent or unsafe behavior outside the task","Lower monitor brightness","Fewer tokens in the tokenizer","Faster database joins"],"correctAnswerIndex":0,"explanation":"Personas should serve task goals and safety constraints."},{"id":"prompt-p1-s4-q3","question":"Which validation step is most appropriate for System Prompts & Personas?","options":["Accepting the first AI or automation output without checking it","Comparing the output with source data, tool logs, and task-specific requirements","Deleting input examples after every run","Changing multiple variables before each test run"],"correctAnswerIndex":1,"explanation":"Reliable AI and automation work requires validating outputs against source data, execution logs, and task requirements."}]}},{"id":"prompt-p1-s5","title":"Practice: Prompt Iteration Lab","description":"Compare prompt versions, run A/B tests, and document improvements.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Practice","Tool"],"resources":[{"label":"Awesome ChatGPT Prompts","type":"tool","url":"https://github.com/f/awesome-chatgpt-prompts"},{"label":"FlowGPT Prompt Library","type":"tool","url":"https://flowgpt.com/"}],"test":{"id":"prompt-p1-s5-test","title":"Practice: Prompt Iteration Lab Check","questions":[{"id":"prompt-p1-s5-q1","question":"What should you change when A/B testing prompts?","options":["One meaningful variable at a time","Every instruction and model at once","Only the file name","The browser language only"],"correctAnswerIndex":0,"explanation":"Controlled changes make it possible to attribute improvements."},{"id":"prompt-p1-s5-q2","question":"What metric best evaluates a summarization prompt?","options":["Faithfulness and coverage against source text","Number of emojis","Model logo color","Random output length"],"correctAnswerIndex":0,"explanation":"Summaries should be accurate to the source and cover key points."},{"id":"prompt-p1-s5-q3","question":"Which validation step is most appropriate for Practice: Prompt Iteration Lab?","options":["Accepting the first AI or automation output without checking it","Comparing the output with source data, tool logs, and task-specific requirements","Deleting input examples after every run","Changing multiple variables before each test run"],"correctAnswerIndex":1,"explanation":"Reliable AI and automation work requires validating outputs against source data, execution logs, and task requirements."}]}}],"finalTest":{"id":"prompt-p1-final","title":"Phase 1 Final: Language Model Fundamentals","questions":[{"id":"prompt-p1-final-q1","question":"In Language Model Fundamentals, what should be defined before a workflow, prompt, model, or dashboard is released?","options":["Only the tool brand used in the demo","Input data, output format, acceptance criteria, owner, and validation method","A promise that the AI will never make mistakes","The color of the final presentation"],"correctAnswerIndex":1,"explanation":"A professional release needs defined inputs, outputs, owners, validation, and acceptance criteria."},{"id":"prompt-p1-final-q2","question":"Which signal indicates a quality problem during Language Model Fundamentals?","options":["The workflow includes source links and logs","Outputs are confident but cannot be traced to source data, rules, or tests","The project has a rollback or revision plan","The team records assumptions and constraints"],"correctAnswerIndex":1,"explanation":"Confident untraceable outputs are a core risk in AI-enabled work."},{"id":"prompt-p1-final-q3","question":"Which artifact best supports maintenance after Language Model Fundamentals is handed off?","options":["A private chat message with no context","A runbook or case study with data sources, configuration, tests, and known limitations","A screenshot of the final result only","An undocumented copy of the prompt or workflow"],"correctAnswerIndex":1,"explanation":"Maintenance requires documented sources, configuration, tests, limitations, and ownership."},{"id":"prompt-p1-final-q4","question":"When a result from Language Model Fundamentals affects customers or business decisions, what should happen before it is trusted?","options":["It should be reviewed against source evidence and domain rules","It should be accepted because it was generated quickly","It should be hidden from stakeholders","It should be reformatted without checking substance"],"correctAnswerIndex":0,"explanation":"Customer-facing and decision-support outputs need evidence checks and domain review."},{"id":"prompt-p1-final-q5","question":"Which metric or check is most useful for proving Language Model Fundamentals created value?","options":["Number of tools mentioned in the project","Measured accuracy, time saved, risk reduced, revenue impact, or stakeholder task success","Whether the demo used the newest AI model","Number of colors used in the interface"],"correctAnswerIndex":1,"explanation":"Professional AI work should connect technical output to measurable quality, efficiency, risk, or business value."}]}},{"id":"prompt-p2","phaseNumber":2,"title":"Advanced Prompting Techniques","description":"Build professional skill in advanced prompting techniques with real tools, standards, and deliverables.","estimatedDuration":"2 weeks","weekRange":"Week 3-4","outcome":"You can apply advanced prompting techniques in portfolio-grade work.","access":"locked","sections":[{"id":"prompt-p2-s1","title":"Chain-of-Thought Prompting","description":"Use reasoning prompts and hidden reasoning alternatives responsibly.","estimatedTime":"3 hours","difficulty":"Advanced","learningTypes":["Reading"],"resources":[{"label":"Wei et al. Chain-of-Thought Paper","type":"article","url":"https://arxiv.org/abs/2201.11903"},{"label":"Google AI: Chain of Thought","type":"article","url":"https://research.google/blog/language-models-perform-reasoning-via-chain-of-thought/"}],"test":{"id":"prompt-p2-s1-test","title":"Chain-of-Thought Prompting Check","questions":[{"id":"prompt-p2-s1-q1","question":"In Chain-of-Thought Prompting, which option is the correct technical choice?","options":["Increasing CSS specificity","Decomposing multi-step reasoning into intermediate steps","Hashing passwords","Turning off all examples"],"correctAnswerIndex":1,"explanation":"CoT-style methods improve reasoning by encouraging stepwise decomposition."},{"id":"prompt-p2-s1-q2","question":"A workflow for Chain-of-Thought Prompting fails because the team used \"Increasing CSS specificity\". What should they use instead?","options":["Decomposing multi-step reasoning into intermediate steps","Increasing CSS specificity","Hashing passwords","Turning off all examples"],"correctAnswerIndex":0,"explanation":"CoT-style methods improve reasoning by encouraging stepwise decomposition."},{"id":"prompt-p2-s1-q3","question":"Which review check best confirms Chain-of-Thought Prompting is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"prompt-p2-s2","title":"Few-Shot & Zero-Shot Strategies","description":"Choose examples when they improve consistency and omit them when they bias outputs.","estimatedTime":"3 hours","difficulty":"Intermediate","learningTypes":["Reading","Practice"],"resources":[{"label":"GPT-3 Paper","type":"article","url":"https://arxiv.org/abs/2005.14165"},{"label":"Hugging Face NLP Course","type":"article","url":"https://huggingface.co/learn/nlp-course/chapter1/1"}],"test":{"id":"prompt-p2-s2-test","title":"Few-Shot & Zero-Shot Strategies Check","questions":[{"id":"prompt-p2-s2-q1","question":"In Few-Shot & Zero-Shot Strategies, which option is the correct technical choice?","options":["Few-shot means fewer tokens always","Few-shot examples demonstrate the target pattern","Zero-shot requires training a model","Examples disable constraints"],"correctAnswerIndex":1,"explanation":"Few-shot prompts teach format and criteria through examples."},{"id":"prompt-p2-s2-q2","question":"A workflow for Few-Shot & Zero-Shot Strategies fails because the team used \"Few-shot means fewer tokens always\". What should they use instead?","options":["Few-shot examples demonstrate the target pattern","Few-shot means fewer tokens always","Zero-shot requires training a model","Examples disable constraints"],"correctAnswerIndex":0,"explanation":"Few-shot prompts teach format and criteria through examples."},{"id":"prompt-p2-s2-q3","question":"Which review check best confirms Few-Shot & Zero-Shot Strategies is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"prompt-p2-s3","title":"ReAct & Tool-Use Prompting","description":"Combine reasoning traces with tool calls and observations.","estimatedTime":"4 hours","difficulty":"Advanced","learningTypes":["Reading","Practice"],"resources":[{"label":"ReAct Paper","type":"article","url":"https://arxiv.org/abs/2210.03629"},{"label":"LangChain Agents","type":"tool","url":"https://js.langchain.com/docs/tutorials/agents/"}],"test":{"id":"prompt-p2-s3-test","title":"ReAct & Tool-Use Prompting Check","questions":[{"id":"prompt-p2-s3-q1","question":"In ReAct & Tool-Use Prompting, which option is the correct technical choice?","options":["Only generating images","Alternating reasoning, actions, and observations","Removing all tools","Single static completion"],"correctAnswerIndex":1,"explanation":"ReAct agents reason about which tool to use and incorporate observations."},{"id":"prompt-p2-s3-q2","question":"A workflow for ReAct & Tool-Use Prompting fails because the team used \"Only generating images\". What should they use instead?","options":["Alternating reasoning, actions, and observations","Only generating images","Removing all tools","Single static completion"],"correctAnswerIndex":0,"explanation":"ReAct agents reason about which tool to use and incorporate observations."},{"id":"prompt-p2-s3-q3","question":"Which review check best confirms ReAct & Tool-Use Prompting is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"prompt-p2-s4","title":"Prompt Chaining & Pipelines","description":"Break complex tasks into typed, testable prompt steps.","estimatedTime":"4 hours","difficulty":"Intermediate","learningTypes":["Tool","Practice"],"resources":[{"label":"LangChain Expression Language","type":"tool","url":"https://js.langchain.com/docs/concepts/lcel/"},{"label":"Microsoft PromptFlow","type":"tool","url":"https://microsoft.github.io/promptflow/"}],"test":{"id":"prompt-p2-s4-test","title":"Prompt Chaining & Pipelines Check","questions":[{"id":"prompt-p2-s4-q1","question":"In Prompt Chaining & Pipelines, which option is the correct technical choice?","options":["One huge prompt for every task","Passing structured outputs from one prompt step to the next","No intermediate validation","Manual copy-paste only"],"correctAnswerIndex":1,"explanation":"Prompt chains make complex workflows more testable and debuggable."},{"id":"prompt-p2-s4-q2","question":"A workflow for Prompt Chaining & Pipelines fails because the team used \"One huge prompt for every task\". What should they use instead?","options":["Passing structured outputs from one prompt step to the next","One huge prompt for every task","No intermediate validation","Manual copy-paste only"],"correctAnswerIndex":0,"explanation":"Prompt chains make complex workflows more testable and debuggable."},{"id":"prompt-p2-s4-q3","question":"Which review check best confirms Prompt Chaining & Pipelines is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}}],"finalTest":{"id":"prompt-p2-final","title":"Phase 2 Final: Advanced Prompting Techniques","questions":[{"id":"prompt-p2-final-q1","question":"In Advanced Prompting Techniques, what should be defined before a workflow, prompt, model, or dashboard is released?","options":["Only the tool brand used in the demo","Input data, output format, acceptance criteria, owner, and validation method","A promise that the AI will never make mistakes","The color of the final presentation"],"correctAnswerIndex":1,"explanation":"A professional release needs defined inputs, outputs, owners, validation, and acceptance criteria."},{"id":"prompt-p2-final-q2","question":"Which signal indicates a quality problem during Advanced Prompting Techniques?","options":["The workflow includes source links and logs","Outputs are confident but cannot be traced to source data, rules, or tests","The project has a rollback or revision plan","The team records assumptions and constraints"],"correctAnswerIndex":1,"explanation":"Confident untraceable outputs are a core risk in AI-enabled work."},{"id":"prompt-p2-final-q3","question":"Which artifact best supports maintenance after Advanced Prompting Techniques is handed off?","options":["A private chat message with no context","A runbook or case study with data sources, configuration, tests, and known limitations","A screenshot of the final result only","An undocumented copy of the prompt or workflow"],"correctAnswerIndex":1,"explanation":"Maintenance requires documented sources, configuration, tests, limitations, and ownership."},{"id":"prompt-p2-final-q4","question":"When a result from Advanced Prompting Techniques affects customers or business decisions, what should happen before it is trusted?","options":["It should be reviewed against source evidence and domain rules","It should be accepted because it was generated quickly","It should be hidden from stakeholders","It should be reformatted without checking substance"],"correctAnswerIndex":0,"explanation":"Customer-facing and decision-support outputs need evidence checks and domain review."},{"id":"prompt-p2-final-q5","question":"Which metric or check is most useful for proving Advanced Prompting Techniques created value?","options":["Number of tools mentioned in the project","Measured accuracy, time saved, risk reduced, revenue impact, or stakeholder task success","Whether the demo used the newest AI model","Number of colors used in the interface"],"correctAnswerIndex":1,"explanation":"Professional AI work should connect technical output to measurable quality, efficiency, risk, or business value."}]}},{"id":"prompt-p3","phaseNumber":3,"title":"Prompt Engineering for Products","description":"Build professional skill in prompt engineering for products with real tools, standards, and deliverables.","estimatedDuration":"2 weeks","weekRange":"Week 5-6","outcome":"You can apply prompt engineering for products in portfolio-grade work.","access":"locked","sections":[{"id":"prompt-p3-s1","title":"Prompt Design for Customer-Facing Apps","description":"Design safe prompts for real users, policies, and edge cases.","estimatedTime":"3 hours","difficulty":"Advanced","learningTypes":["Reading"],"resources":[{"label":"Anthropic Prompt Engineering","type":"article","url":"https://docs.anthropic.com/en/docs/build-with-claude/prompt-engineering/overview"},{"label":"OpenAI Usage Policies","type":"article","url":"https://openai.com/policies/usage-policies/"}],"test":{"id":"prompt-p3-s1-test","title":"Prompt Design for Customer-Facing Apps Check","questions":[{"id":"prompt-p3-s1-q1","question":"In Prompt Design for Customer-Facing Apps, which option is the correct technical choice?","options":["No safety instructions","Clear refusal, escalation, and safe-completion behavior","Unbounded persona roleplay","Hiding policy from evaluation"],"correctAnswerIndex":1,"explanation":"Customer-facing prompts need safe behavior and escalation paths."},{"id":"prompt-p3-s1-q2","question":"A workflow for Prompt Design for Customer-Facing Apps fails because the team used \"No safety instructions\". What should they use instead?","options":["Clear refusal, escalation, and safe-completion behavior","No safety instructions","Unbounded persona roleplay","Hiding policy from evaluation"],"correctAnswerIndex":0,"explanation":"Customer-facing prompts need safe behavior and escalation paths."},{"id":"prompt-p3-s1-q3","question":"Which review check best confirms Prompt Design for Customer-Facing Apps is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"prompt-p3-s2","title":"Evaluation & Red-Teaming Prompts","description":"Test prompt robustness with adversarial and benchmark-style cases.","estimatedTime":"4 hours","difficulty":"Advanced","learningTypes":["Reading","Practice"],"resources":[{"label":"Stanford HELM","type":"article","url":"https://crfm.stanford.edu/helm/latest/"},{"label":"PromptBench Paper","type":"article","url":"https://arxiv.org/abs/2306.04528"}],"test":{"id":"prompt-p3-s2-test","title":"Evaluation & Red-Teaming Prompts Check","questions":[{"id":"prompt-p3-s2-q1","question":"In Evaluation & Red-Teaming Prompts, which option is the correct technical choice?","options":["Only checking one happy path","Adversarial test cases that probe jailbreaks and task failures","Changing prompts without logs","Relying on vibes"],"correctAnswerIndex":1,"explanation":"Prompt evaluation needs systematic, repeatable test suites."},{"id":"prompt-p3-s2-q2","question":"A workflow for Evaluation & Red-Teaming Prompts fails because the team used \"Only checking one happy path\". What should they use instead?","options":["Adversarial test cases that probe jailbreaks and task failures","Only checking one happy path","Changing prompts without logs","Relying on vibes"],"correctAnswerIndex":0,"explanation":"Prompt evaluation needs systematic, repeatable test suites."},{"id":"prompt-p3-s2-q3","question":"Which review check best confirms Evaluation & Red-Teaming Prompts is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"prompt-p3-s3","title":"Structured Output & JSON Mode","description":"Constrain model output for parsers, APIs, and downstream automations.","estimatedTime":"3 hours","difficulty":"Intermediate","learningTypes":["Reading","Tool"],"resources":[{"label":"OpenAI Structured Outputs","type":"article","url":"https://platform.openai.com/docs/guides/structured-outputs"},{"label":"Instructor Library","type":"tool","url":"https://github.com/instructor-ai/instructor"}],"test":{"id":"prompt-p3-s3-test","title":"Structured Output & JSON Mode Check","questions":[{"id":"prompt-p3-s3-q1","question":"In Structured Output & JSON Mode, which option is the correct technical choice?","options":["Free-form paragraphs only","Schema-constrained JSON that downstream code can validate","Screenshots of data","Random indentation"],"correctAnswerIndex":1,"explanation":"Structured outputs reduce parsing failures."},{"id":"prompt-p3-s3-q2","question":"A workflow for Structured Output & JSON Mode fails because the team used \"Free-form paragraphs only\". What should they use instead?","options":["Schema-constrained JSON that downstream code can validate","Free-form paragraphs only","Screenshots of data","Random indentation"],"correctAnswerIndex":0,"explanation":"Structured outputs reduce parsing failures."},{"id":"prompt-p3-s3-q3","question":"Which review check best confirms Structured Output & JSON Mode is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"prompt-p3-s4","title":"Prompt Version Control & Management","description":"Track prompt changes, evaluation results, and production regressions.","estimatedTime":"3 hours","difficulty":"Intermediate","learningTypes":["Tool"],"resources":[{"label":"PromptLayer Docs","type":"tool","url":"https://docs.promptlayer.com/"},{"label":"LangSmith Docs","type":"tool","url":"https://docs.smith.langchain.com/"}],"test":{"id":"prompt-p3-s4-test","title":"Prompt Version Control & Management Check","questions":[{"id":"prompt-p3-s4-q1","question":"In Prompt Version Control & Management, which option is the correct technical choice?","options":["Editing production prompts without history","Versioned prompts with traces and evaluation results","No test cases","Deleting logs"],"correctAnswerIndex":1,"explanation":"Prompt management tools support traceability and regression testing."},{"id":"prompt-p3-s4-q2","question":"A workflow for Prompt Version Control & Management fails because the team used \"Editing production prompts without history\". What should they use instead?","options":["Versioned prompts with traces and evaluation results","Editing production prompts without history","No test cases","Deleting logs"],"correctAnswerIndex":0,"explanation":"Prompt management tools support traceability and regression testing."},{"id":"prompt-p3-s4-q3","question":"Which review check best confirms Prompt Version Control & Management is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}}],"finalTest":{"id":"prompt-p3-final","title":"Phase 3 Final: Prompt Engineering for Products","questions":[{"id":"prompt-p3-final-q1","question":"In Prompt Engineering for Products, what should be defined before a workflow, prompt, model, or dashboard is released?","options":["Only the tool brand used in the demo","Input data, output format, acceptance criteria, owner, and validation method","A promise that the AI will never make mistakes","The color of the final presentation"],"correctAnswerIndex":1,"explanation":"A professional release needs defined inputs, outputs, owners, validation, and acceptance criteria."},{"id":"prompt-p3-final-q2","question":"Which signal indicates a quality problem during Prompt Engineering for Products?","options":["The workflow includes source links and logs","Outputs are confident but cannot be traced to source data, rules, or tests","The project has a rollback or revision plan","The team records assumptions and constraints"],"correctAnswerIndex":1,"explanation":"Confident untraceable outputs are a core risk in AI-enabled work."},{"id":"prompt-p3-final-q3","question":"Which artifact best supports maintenance after Prompt Engineering for Products is handed off?","options":["A private chat message with no context","A runbook or case study with data sources, configuration, tests, and known limitations","A screenshot of the final result only","An undocumented copy of the prompt or workflow"],"correctAnswerIndex":1,"explanation":