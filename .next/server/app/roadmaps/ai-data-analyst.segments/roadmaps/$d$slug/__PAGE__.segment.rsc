0:{"rsc":["$","$1","c",{"children":[["$","$L2",null,{"roadmap":{"id":"3","slug":"ai-data-analyst","title":"AI Data Analyst","description":"Use statistics, SQL, Python, visualization, and LLM-assisted analysis to turn raw data into decisions.","category":"Data","level":"Beginner to Intermediate","duration":"12 weeks","status":"mvp-ready","totalEstimatedHours":78,"phases":[{"id":"data-p1","phaseNumber":1,"title":"Data & AI Fundamentals","description":"Build the statistical, Python, visualization, and LLM-assisted analysis foundation for modern data work.","estimatedDuration":"2 weeks","weekRange":"Week 1-2","outcome":"You can inspect a real dataset, ask better analytical questions, and communicate initial findings.","access":"free","sections":[{"id":"data-p1-s1","title":"Statistics for Data Analysis","description":"Learn averages, spread, distributions, hypothesis tests, and p-values.","estimatedTime":"5 hours","difficulty":"Beginner","learningTypes":["Video","Reading"],"resources":[{"label":"Khan Academy Statistics","type":"article","url":"https://www.khanacademy.org/math/statistics-probability"},{"label":"StatQuest YouTube Channel","type":"video","url":"https://www.youtube.com/@statquest"}],"test":{"id":"data-p1-s1-test","title":"Statistics for Data Analysis Check","questions":[{"id":"data-p1-s1-q1","question":"Which metric is most sensitive to extreme outliers?","options":["Mean","Median","Mode","Interquartile range"],"correctAnswerIndex":0,"explanation":"The mean shifts strongly when extreme values are added."},{"id":"data-p1-s1-q2","question":"What does a p-value measure?","options":["The probability of observing data at least this extreme under the null hypothesis","The size of a database table","The slope of every regression line","The number of missing cells"],"correctAnswerIndex":0,"explanation":"A p-value is interpreted relative to a null hypothesis."},{"id":"data-p1-s1-q3","question":"Which validation step is most appropriate for Statistics for Data Analysis?","options":["Accepting the first AI or automation output without checking it","Comparing the output with source data, tool logs, and task-specific requirements","Deleting input examples after every run","Changing multiple variables before each test run"],"correctAnswerIndex":1,"explanation":"Reliable AI and automation work requires validating outputs against source data, execution logs, and task requirements."}]}},{"id":"data-p1-s2","title":"Python for Data Analysis Basics","description":"Use notebooks, pandas DataFrames, indexing, data types, and simple transformations.","estimatedTime":"7 hours","difficulty":"Beginner","learningTypes":["Video","Practice"],"resources":[{"label":"freeCodeCamp Python for Data Science","type":"video","url":"https://www.youtube.com/watch?v=r-uOLxNrNk8"},{"label":"Kaggle Python Course","type":"practice","url":"https://www.kaggle.com/learn/python"}],"test":{"id":"data-p1-s2-test","title":"Python for Data Analysis Basics Check","questions":[{"id":"data-p1-s2-q1","question":"Which Python library is primarily used for DataFrame manipulation?","options":["pandas","matplotlib","scikit-learn","pytest"],"correctAnswerIndex":0,"explanation":"pandas provides DataFrame and Series data structures."},{"id":"data-p1-s2-q2","question":"In pandas, what does df.loc usually select by?","options":["Labels","Pixel coordinates","GPU memory","HTTP status"],"correctAnswerIndex":0,"explanation":"loc is label-based selection."},{"id":"data-p1-s2-q3","question":"Which validation step is most appropriate for Python for Data Analysis Basics?","options":["Accepting the first AI or automation output without checking it","Comparing the output with source data, tool logs, and task-specific requirements","Deleting input examples after every run","Changing multiple variables before each test run"],"correctAnswerIndex":1,"explanation":"Reliable AI and automation work requires validating outputs against source data, execution logs, and task requirements."}]}},{"id":"data-p1-s3","title":"Working with Data in ChatGPT/Claude","description":"Upload CSVs, ask analytical questions, check calculations, and interpret AI-generated findings.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"OpenAI Data Analysis with ChatGPT","type":"article","url":"https://help.openai.com/en/articles/8437071-data-analysis-with-chatgpt"},{"label":"Using Files with Claude","type":"article","url":"https://support.anthropic.com/en/articles/8241126-using-files-with-claude"}],"test":{"id":"data-p1-s3-test","title":"Working with Data in ChatGPT/Claude Check","questions":[{"id":"data-p1-s3-q1","question":"What should you do before trusting an AI-generated data insight?","options":["Verify the calculation or reproduce it with code","Copy it into a slide immediately","Delete the source CSV","Increase chart saturation"],"correctAnswerIndex":0,"explanation":"LLM analysis can be wrong, so key findings need reproducible checks."},{"id":"data-p1-s3-q2","question":"Which prompt is best for a CSV analysis task?","options":["Ask a specific question and request assumptions, code, and caveats","Say 'analyze everything' only","Ask for a random chart","Hide column definitions"],"correctAnswerIndex":0,"explanation":"Specific analytical prompts produce more auditable results."},{"id":"data-p1-s3-q3","question":"Which validation step is most appropriate for Working with Data in ChatGPT/Claude?","options":["Accepting the first AI or automation output without checking it","Comparing the output with source data, tool logs, and task-specific requirements","Deleting input examples after every run","Changing multiple variables before each test run"],"correctAnswerIndex":1,"explanation":"Reliable AI and automation work requires validating outputs against source data, execution logs, and task requirements."}]}},{"id":"data-p1-s4","title":"Data Visualisation Principles","description":"Choose charts, use color intentionally, and avoid misleading encodings.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading"],"resources":[{"label":"Data-to-Viz","type":"article","url":"https://www.data-to-viz.com/"},{"label":"Storytelling with Data Blog","type":"article","url":"https://www.storytellingwithdata.com/blog"}],"test":{"id":"data-p1-s4-test","title":"Data Visualisation Principles Check","questions":[{"id":"data-p1-s4-q1","question":"Which chart is usually best for a time-series trend?","options":["Line chart","Pie chart","Word cloud","Stack of icons"],"correctAnswerIndex":0,"explanation":"Line charts show change over a continuous time axis."},{"id":"data-p1-s4-q2","question":"Why can truncated bar chart axes mislead viewers?","options":["They exaggerate differences between bars","They always reduce file size","They improve statistical power","They remove missing values"],"correctAnswerIndex":0,"explanation":"Bars encode magnitude from the baseline, so truncation can distort comparisons."},{"id":"data-p1-s4-q3","question":"Which validation step is most appropriate for Data Visualisation Principles?","options":["Accepting the first AI or automation output without checking it","Comparing the output with source data, tool logs, and task-specific requirements","Deleting input examples after every run","Changing multiple variables before each test run"],"correctAnswerIndex":1,"explanation":"Reliable AI and automation work requires validating outputs against source data, execution logs, and task requirements."}]}},{"id":"data-p1-s5","title":"Hands-On: Analyse a Real Dataset","description":"Use the Titanic dataset in Colab to practice EDA, missing values, outliers, and initial insights.","estimatedTime":"5 hours","difficulty":"Beginner","learningTypes":["Practice","Project"],"resources":[{"label":"Kaggle Titanic Dataset","type":"practice","url":"https://www.kaggle.com/c/titanic"},{"label":"Google Colab Intro","type":"tool","url":"https://colab.research.google.com/notebooks/intro.ipynb"}],"test":{"id":"data-p1-s5-test","title":"Hands-On: Analyse a Real Dataset Check","questions":[{"id":"data-p1-s5-q1","question":"What is a common first step in exploratory data analysis?","options":["Inspect rows, columns, data types, missing values, and summary statistics","Train a neural network immediately","Publish a dashboard before checking data","Delete categorical columns"],"correctAnswerIndex":0,"explanation":"EDA starts with understanding structure and quality."},{"id":"data-p1-s5-q2","question":"How should missing values be handled?","options":["Investigate pattern and choose deletion, imputation, or separate category based on context","Always replace with zero","Always delete the dataset","Ignore them in every chart"],"correctAnswerIndex":0,"explanation":"Missingness strategy depends on meaning, volume, and analytical goal."},{"id":"data-p1-s5-q3","question":"Which validation step is most appropriate for Hands-On: Analyse a Real Dataset?","options":["Accepting the first AI or automation output without checking it","Comparing the output with source data, tool logs, and task-specific requirements","Deleting input examples after every run","Changing multiple variables before each test run"],"correctAnswerIndex":1,"explanation":"Reliable AI and automation work requires validating outputs against source data, execution logs, and task requirements."}]}}],"finalTest":{"id":"data-p1-final","title":"Phase 1 Final: Data & AI Fundamentals","questions":[{"id":"data-p1-final-q1","question":"In Data & AI Fundamentals, what should be defined before a workflow, prompt, model, or dashboard is released?","options":["Only the tool brand used in the demo","Input data, output format, acceptance criteria, owner, and validation method","A promise that the AI will never make mistakes","The color of the final presentation"],"correctAnswerIndex":1,"explanation":"A professional release needs defined inputs, outputs, owners, validation, and acceptance criteria."},{"id":"data-p1-final-q2","question":"Which signal indicates a quality problem during Data & AI Fundamentals?","options":["The workflow includes source links and logs","Outputs are confident but cannot be traced to source data, rules, or tests","The project has a rollback or revision plan","The team records assumptions and constraints"],"correctAnswerIndex":1,"explanation":"Confident untraceable outputs are a core risk in AI-enabled work."},{"id":"data-p1-final-q3","question":"Which artifact best supports maintenance after Data & AI Fundamentals is handed off?","options":["A private chat message with no context","A runbook or case study with data sources, configuration, tests, and known limitations","A screenshot of the final result only","An undocumented copy of the prompt or workflow"],"correctAnswerIndex":1,"explanation":"Maintenance requires documented sources, configuration, tests, limitations, and ownership."},{"id":"data-p1-final-q4","question":"When a result from Data & AI Fundamentals affects customers or business decisions, what should happen before it is trusted?","options":["It should be reviewed against source evidence and domain rules","It should be accepted because it was generated quickly","It should be hidden from stakeholders","It should be reformatted without checking substance"],"correctAnswerIndex":0,"explanation":"Customer-facing and decision-support outputs need evidence checks and domain review."},{"id":"data-p1-final-q5","question":"Which metric or check is most useful for proving Data & AI Fundamentals created value?","options":["Number of tools mentioned in the project","Measured accuracy, time saved, risk reduced, revenue impact, or stakeholder task success","Whether the demo used the newest AI model","Number of colors used in the interface"],"correctAnswerIndex":1,"explanation":"Professional AI work should connect technical output to measurable quality, efficiency, risk, or business value."}]}},{"id":"data-p2","phaseNumber":2,"title":"SQL & Database Querying","description":"Build professional skill in sql & database querying with real tools, standards, and deliverables.","estimatedDuration":"2 weeks","weekRange":"Week 3-4","outcome":"You can apply sql & database querying in portfolio-grade work.","access":"locked","sections":[{"id":"data-p2-s1","title":"SQL SELECT, WHERE, GROUP BY","description":"Query relational data and aggregate business metrics.","estimatedTime":"4 hours","difficulty":"Beginner","learningTypes":["Practice"],"resources":[{"label":"SQLBolt","type":"practice","url":"https://sqlbolt.com/"},{"label":"PostgreSQL Tutorial","type":"article","url":"https://www.postgresql.org/docs/current/tutorial.html"}],"test":{"id":"data-p2-s1-test","title":"SQL SELECT, WHERE, GROUP BY Check","questions":[{"id":"data-p2-s1-q1","question":"In SQL SELECT, WHERE, GROUP BY, which option is the correct technical choice?","options":["ORDER BY creates new tables","GROUP BY aggregates rows by one or more columns","WHERE runs after aggregation only","SELECT encrypts records"],"correctAnswerIndex":1,"explanation":"GROUP BY is used with aggregate functions such as COUNT, SUM, and AVG."},{"id":"data-p2-s1-q2","question":"A workflow for SQL SELECT, WHERE, GROUP BY fails because the team used \"ORDER BY creates new tables\". What should they use instead?","options":["GROUP BY aggregates rows by one or more columns","ORDER BY creates new tables","WHERE runs after aggregation only","SELECT encrypts records"],"correctAnswerIndex":0,"explanation":"GROUP BY is used with aggregate functions such as COUNT, SUM, and AVG."},{"id":"data-p2-s1-q3","question":"Which review check best confirms SQL SELECT, WHERE, GROUP BY is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"data-p2-s2","title":"Joins and Data Modeling","description":"Combine tables with keys and understand one-to-many relationships.","estimatedTime":"4 hours","difficulty":"Intermediate","learningTypes":["Practice"],"resources":[{"label":"SQLBolt","type":"practice","url":"https://sqlbolt.com/"},{"label":"PostgreSQL Tutorial","type":"article","url":"https://www.postgresql.org/docs/current/tutorial.html"}],"test":{"id":"data-p2-s2-test","title":"Joins and Data Modeling Check","questions":[{"id":"data-p2-s2-q1","question":"In Joins and Data Modeling, which option is the correct technical choice?","options":["INNER JOIN deletes duplicates","INNER JOIN returns matching rows from both tables","INNER JOIN creates charts","INNER JOIN trains classifiers"],"correctAnswerIndex":1,"explanation":"Joins combine related rows using key relationships."},{"id":"data-p2-s2-q2","question":"A workflow for Joins and Data Modeling fails because the team used \"INNER JOIN deletes duplicates\". What should they use instead?","options":["INNER JOIN returns matching rows from both tables","INNER JOIN deletes duplicates","INNER JOIN creates charts","INNER JOIN trains classifiers"],"correctAnswerIndex":0,"explanation":"Joins combine related rows using key relationships."},{"id":"data-p2-s2-q3","question":"Which review check best confirms Joins and Data Modeling is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"data-p2-s3","title":"Window Functions","description":"Rank, lag, and calculate rolling metrics without collapsing rows.","estimatedTime":"4 hours","difficulty":"Intermediate","learningTypes":["Reading","Practice"],"resources":[{"label":"PostgreSQL Window Functions","type":"article","url":"https://www.postgresql.org/docs/current/tutorial-window.html"},{"label":"SQLBolt","type":"practice","url":"https://sqlbolt.com/"}],"test":{"id":"data-p2-s3-test","title":"Window Functions Check","questions":[{"id":"data-p2-s3-q1","question":"In Window Functions, which option is the correct technical choice?","options":["Window functions only resize dashboards","Window functions calculate across related rows while preserving row detail","They require image data","They disable sorting"],"correctAnswerIndex":1,"explanation":"Window functions support ranking, moving averages, and comparisons within partitions."},{"id":"data-p2-s3-q2","question":"A workflow for Window Functions fails because the team used \"Window functions only resize dashboards\". What should they use instead?","options":["Window functions calculate across related rows while preserving row detail","Window functions only resize dashboards","They require image data","They disable sorting"],"correctAnswerIndex":0,"explanation":"Window functions support ranking, moving averages, and comparisons within partitions."},{"id":"data-p2-s3-q3","question":"Which review check best confirms Window Functions is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}}],"finalTest":{"id":"data-p2-final","title":"Phase 2 Final: SQL & Database Querying","questions":[{"id":"data-p2-final-q1","question":"In SQL & Database Querying, what should be de