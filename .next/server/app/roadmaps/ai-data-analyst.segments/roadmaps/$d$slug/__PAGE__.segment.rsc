ions":["Number of tools mentioned in the project","Measured accuracy, time saved, risk reduced, revenue impact, or stakeholder task success","Whether the demo used the newest AI model","Number of colors used in the interface"],"correctAnswerIndex":1,"explanation":"Professional AI work should connect technical output to measurable quality, efficiency, risk, or business value."}]}},{"id":"data-p3","phaseNumber":3,"title":"Python Analytics & Visualization","description":"Build professional skill in python analytics & visualization with real tools, standards, and deliverables.","estimatedDuration":"2 weeks","weekRange":"Week 5-6","outcome":"You can apply python analytics & visualization in portfolio-grade work.","access":"locked","sections":[{"id":"data-p3-s1","title":"Pandas Cleaning Workflows","description":"Clean missing values, types, duplicates, and derived columns.","estimatedTime":"5 hours","difficulty":"Intermediate","learningTypes":["Practice"],"resources":[{"label":"Kaggle Pandas","type":"practice","url":"https://www.kaggle.com/learn/pandas"},{"label":"Kaggle Data Cleaning","type":"practice","url":"https://www.kaggle.com/learn/data-cleaning"}],"test":{"id":"data-p3-s1-test","title":"Pandas Cleaning Workflows Check","questions":[{"id":"data-p3-s1-q1","question":"In Pandas Cleaning Workflows, which option is the correct technical choice?","options":["Group strings as dates","Convert data types before grouping or calculating metrics","Ignore duplicate IDs","Plot before cleaning every time"],"correctAnswerIndex":1,"explanation":"Correct types prevent broken filters, aggregations, and visualizations."},{"id":"data-p3-s1-q2","question":"A workflow for Pandas Cleaning Workflows fails because the team used \"Group strings as dates\". What should they use instead?","options":["Convert data types before grouping or calculating metrics","Group strings as dates","Ignore duplicate IDs","Plot before cleaning every time"],"correctAnswerIndex":0,"explanation":"Correct types p