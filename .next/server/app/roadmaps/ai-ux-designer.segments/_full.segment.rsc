4:["$","$Lf",null,{"roadmap":{"id":"7","slug":"ai-ux-designer","title":"AI UX Designer","description":"Design AI-assisted product experiences that are understandable, controllable, ethical, and useful.","category":"Design","level":"Beginner to Intermediate","duration":"12 weeks","status":"mvp-ready","totalEstimatedHours":66,"phases":[{"id":"aud-p1","phaseNumber":1,"title":"AI UX Designer Foundations","description":"Learn the core concepts, tools, and safety checks for ai ux designer.","estimatedDuration":"2 weeks","weekRange":"Week 1-2","outcome":"You can complete a practical first workflow for ai ux designer.","access":"free","sections":[{"id":"ux-p1-s1","title":"AI UX Patterns","description":"Learn AI interaction patterns: suggestions, copilots, generators, agents, and review loops.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"NN/g AI UX","type":"article","url":"https://www.nngroup.com/articles/ai-user-experience/"},{"label":"Google Responsible AI Practices","type":"article","url":"https://ai.google/responsibility/responsible-ai-practices/"}],"test":{"id":"ux-p1-s1-test","title":"AI UX Patterns Check","questions":[{"id":"ux-p1-s1-q1","question":"In AI UX Patterns, which option is the correct technical choice?","options":["Unstructured guessing without validation","Human-in-the-loop interaction pattern for uncertain AI output","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"Human-in-the-loop interaction pattern for uncertain AI output is the professional technique for this topic."},{"id":"ux-p1-s1-q2","question":"A workflow for AI UX Patterns fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["Human-in-the-loop interaction pattern for uncertain AI output","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"Human-in-the-loop interaction pattern for uncertain AI output is the professional technique for this topic."},{"id":"ux-p1-s1-q3","question":"Which review check best confirms AI UX Patterns is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"ux-p1-s2","title":"Figma AI and Design Acceleration","description":"Use AI features and plugins while keeping design intent explicit.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"Figma First Draft Help","type":"tool","url":"https://help.figma.com/hc/en-us/articles/23954856027159-Use-First-Draft-to-generate-designs"},{"label":"NN/g AI UX","type":"article","url":"https://www.nngroup.com/articles/ai-user-experience/"}],"test":{"id":"ux-p1-s2-test","title":"Figma AI and Design Acceleration Check","questions":[{"id":"ux-p1-s2-q1","question":"In Figma AI and Design Acceleration, which option is the correct technical choice?","options":["Unstructured guessing without validation","AI-generated draft refined with design-system constraints","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"AI-generated draft refined with design-system constraints is the professional technique for this topic."},{"id":"ux-p1-s2-q2","question":"A workflow for Figma AI and Design Acceleration fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["AI-generated draft refined with design-system constraints","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"AI-generated draft refined with design-system constraints is the professional technique for this topic."},{"id":"ux-p1-s2-q3","question":"Which review check best confirms Figma AI and Design Acceleration is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"ux-p1-s3","title":"User Research with AI","description":"Summarize interviews, cluster themes, and avoid synthetic-user overtrust.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"OpenAI Prompt Engineering Guide","type":"article","url":"https://platform.openai.com/docs/guides/prompt-engineering"},{"label":"Mind the Product","type":"article","url":"https://www.mindtheproduct.com/"}],"test":{"id":"ux-p1-s3-test","title":"User Research with AI Check","questions":[{"id":"ux-p1-s3-q1","question":"In User Research with AI, which option is the correct technical choice?","options":["Unstructured guessing without validation","AI-assisted synthesis checked against source evidence","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"AI-assisted synthesis checked against source evidence is the professional technique for this topic."},{"id":"ux-p1-s3-q2","question":"A workflow for User Research with AI fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["AI-assisted synthesis checked against source evidence","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"AI-assisted synthesis checked against source evidence is the professional technique for this topic."},{"id":"ux-p1-s3-q3","question":"Which review check best confirms User Research with AI is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"ux-p1-s4","title":"Designing for Trust and Control","description":"Add confidence, editability, undo, provenance, and escalation paths.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"Google Responsible AI Practices","type":"article","url":"https://ai.google/responsibility/responsible-ai-practices/"},{"label":"NIST AI RMF","type":"article","url":"https://www.nist.gov/itl/ai-risk-management-framework"}],"test":{"id":"ux-p1-s4-test","title":"Designing for Trust and Control Check","questions":[{"id":"ux-p1-s4-q1","question":"In Designing for Trust and Control, which option is the correct technical choice?","options":["Unstructured guessing without validation","Controls for review, override, and source visibility","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"Controls for review, override, and source visibility is the professional technique for this topic."},{"id":"ux-p1-s4-q2","question":"A workflow for Designing for Trust and Control fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["Controls for review, override, and source visibility","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"Controls for review, override, and source visibility is the professional technique for this topic."},{"id":"ux-p1-s4-q3","question":"Which review check best confirms Designing for Trust and Control is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"ux-p1-s5","title":"Ethical AI Design Basics","description":"Consider bias, consent, privacy, explainability, and user agency.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"EU AI Act Overview","type":"article","url":"https://artificialintelligenceact.eu/"},{"label":"NIST AI RMF","type":"article","url":"https://www.nist.gov/itl/ai-risk-management-framework"}],"test":{"id":"ux-p1-s5-test","title":"Ethical AI Design Basics Check","questions":[{"id":"ux-p1-s5-q1","question":"In Ethical AI Design Basics, which option is the correct technical choice?","options":["Unstructured guessing without validation","Bias and privacy review before shipping AI flows","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"Bias and privacy review before shipping AI flows is the professional technique for this topic."},{"id":"ux-p1-s5-q2","question":"A workflow for Ethical AI Design Basics fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["Bias and privacy review before shipping AI flows","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"Bias and privacy review before shipping AI flows is the professional technique for this topic."},{"id":"ux-p1-s5-q3","question":"Which review check best confirms Ethical AI Design Basics is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}}],"finalTest":{"id":"aud-p1-final","title":"Phase 1 Final: AI UX Designer Foundations","questions":[{"id":"aud-p1-final-q1","question":"In AI UX Designer Foundations, what should be defined before a workflow, prompt, model, or dashboard is released?","options":["Only the tool brand used in the demo","Input data, output format, acceptance criteria, owner, and validation method","A promise that the AI will never make mistakes","The color of the final presentation"],"correctAnswerIndex":1,"explanation":"A professional release needs defined inputs, outputs, owners, validation, and acceptance criteria."},{"id":"aud-p1-final-q2","question":"Which signal indicates a quality problem during AI UX Designer Foundations?","options":["The workflow includes source links and logs","Outputs are confident but cannot be traced to source data, rules, or tests","The project has a rollback or revision plan","The team records assumptions and constraints"],"correctAnswerIndex":1,"explanation":"Confident untraceable outputs are a core risk in AI-enabled work."},{"id":"aud-p1-final-q3","question":"Which artifact best supports maintenance after AI UX Designer Foundations is handed off?","options":["A private chat message with no context","A runbook or case study with data sources, configuration, tests, and known limitations","A screenshot of the final result only","An undocumented copy of the prompt or workflow"],"correctAnswerIndex":1,"explanation":"Maintenance requires documented sources, configuration, tests, limitations, and ownership."},{"id":"aud-p1-final-q4","question":"When a result from AI UX Designer Foundations affects customers or business decisions, what should happen before it is trusted?","options":["It should be reviewed against source evidence and domain rules","It should be accepted because it was generated quickly","It should be hidden from stakeholders","It should be reformatted without checking substance"],"correctAnswerIndex":0,"explanation":"Customer-facing and decision-support outputs need evidence checks and domain review."},{"id":"aud-p1-final-q5","question":"Which metric or check is most useful for proving AI UX Designer Foundations created value?","options":["Number of tools mentioned in the project","Measured accuracy, time saved, risk reduced, revenue impact, or stakeholder task success","Whether the demo used the newest AI model","Number of colors used in the interface"],"correctAnswerIndex":1,"explanation":"Professional AI work should connect technical output to measurable quality, efficiency, risk, or business value."}]}},{"id":"aud-p2","phaseNumber":2,"title":"AI Interaction Patterns","description":"Build professional skill in ai interaction patterns with real tools, standards, and deliverables.","estimatedDuration":"2 weeks","weekRange":"Week 3-4","outcome":"You can apply ai interaction patterns in portfolio-grade work.","access":"locked","sections":[{"id":"aud-p2-s1","title":"AI Interaction Patterns: Core Workflow","description":"Practice the core workflow for ai interaction patterns.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"NN/g AI UX","type":"article","url":"https://www.nngroup.com/articles/ai-user-experience/"},{"label":"Figma First Draft Help","type":"tool","url":"https://help.figma.com/hc/en