4:["$","$Lf",null,{"roadmap":{"id":"4","slug":"ai-content-creator","title":"AI Content Creator","description":"Create SEO-informed articles, social content, newsletters, and scripts with AI while preserving strategy and editorial quality.","category":"Content","level":"Beginner","duration":"12 weeks","status":"mvp-ready","totalEstimatedHours":66,"phases":[{"id":"acc-p1","phaseNumber":1,"title":"AI Content Creator Foundations","description":"Learn the core concepts, tools, and safety checks for ai content creator.","estimatedDuration":"2 weeks","weekRange":"Week 1-2","outcome":"You can complete a practical first workflow for ai content creator.","access":"free","sections":[{"id":"content-p1-s1","title":"AI Writing Workflow Basics","description":"Use AI for ideation, drafting, editing, and repurposing without losing editorial judgment.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"HubSpot Content Marketing Guide","type":"article","url":"https://blog.hubspot.com/marketing/content-marketing"},{"label":"OpenAI Prompt Engineering Guide","type":"article","url":"https://platform.openai.com/docs/guides/prompt-engineering"}],"test":{"id":"content-p1-s1-test","title":"AI Writing Workflow Basics Check","questions":[{"id":"content-p1-s1-q1","question":"In AI Writing Workflow Basics, which option is the correct technical choice?","options":["Unstructured guessing without validation","Human-edited AI drafts with source and audience constraints","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"Human-edited AI drafts with source and audience constraints is the professional technique for this topic."},{"id":"content-p1-s1-q2","question":"A workflow for AI Writing Workflow Basics fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["Human-edited AI drafts with source and audience constraints","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"Human-edited AI drafts with source and audience constraints is the professional technique for this topic."},{"id":"content-p1-s1-q3","question":"Which review check best confirms AI Writing Workflow Basics is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"content-p1-s2","title":"SEO Fundamentals for AI Content","description":"Learn search intent, page structure, internal links, and technical SEO basics.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"Google SEO Starter Guide","type":"article","url":"https://developers.google.com/search/docs/fundamentals/seo-starter-guide"},{"label":"freeCodeCamp SEO for Developers","type":"article","url":"https://www.freecodecamp.org/news/seo-for-developers/"}],"test":{"id":"content-p1-s2-test","title":"SEO Fundamentals for AI Content Check","questions":[{"id":"content-p1-s2-q1","question":"In SEO Fundamentals for AI Content, which option is the correct technical choice?","options":["Unstructured guessing without validation","Search intent matched to content structure and keywords","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"Search intent matched to content structure and keywords is the professional technique for this topic."},{"id":"content-p1-s2-q2","question":"A workflow for SEO Fundamentals for AI Content fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["Search intent matched to content structure and keywords","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"Search intent matched to content structure and keywords is the professional technique for this topic."},{"id":"content-p1-s2-q3","question":"Which review check best confirms SEO Fundamentals for AI Content is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"content-p1-s3","title":"Content Strategy and Editorial Calendars","description":"Plan pillars, topics, cadence, audience fit, and review stages.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"HubSpot Content Marketing Guide","type":"article","url":"https://blog.hubspot.com/marketing/content-marketing"},{"label":"Notion Templates","type":"tool","url":"https://www.notion.com/templates"}],"test":{"id":"content-p1-s3-test","title":"Content Strategy and Editorial Calendars Check","questions":[{"id":"content-p1-s3-q1","question":"In Content Strategy and Editorial Calendars, which option is the correct technical choice?","options":["Unstructured guessing without validation","Content pillars mapped to audience problems and funnel stage","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"Content pillars mapped to audience problems and funnel stage is the professional technique for this topic."},{"id":"content-p1-s3-q2","question":"A workflow for Content Strategy and Editorial Calendars fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["Content pillars mapped to audience problems and funnel stage","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"Content pillars mapped to audience problems and funnel stage is the professional technique for this topic."},{"id":"content-p1-s3-q3","question":"Which review check best confirms Content Strategy and Editorial Calendars is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"content-p1-s4","title":"Social Media Repurposing","description":"Turn one source asset into platform-specific posts and hooks.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"YouTube Creators","type":"video","url":"https://www.youtube.com/creators/"},{"label":"FlowGPT","type":"tool","url":"https://flowgpt.com/"}],"test":{"id":"content-p1-s4-test","title":"Social Media Repurposing Check","questions":[{"id":"content-p1-s4-q1","question":"In Social Media Repurposing, which option is the correct technical choice?","options":["Unstructured guessing without validation","Platform-specific adaptation instead of one identical post everywhere","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"Platform-specific adaptation instead of one identical post everywhere is the professional technique for this topic."},{"id":"content-p1-s4-q2","question":"A workflow for Social Media Repurposing fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["Platform-specific adaptation instead of one identical post everywhere","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"Platform-specific adaptation instead of one identical post everywhere is the professional technique for this topic."},{"id":"content-p1-s4-q3","question":"Which review check best confirms Social Media Repurposing is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"content-p1-s5","title":"Video Scripting with AI","description":"Create short-form and long-form scripts with hooks, beats, and calls to action.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"YouTube Creators","type":"video","url":"https://www.youtube.com/creators/"},{"label":"OpenAI Text Generation Guide","type":"article","url":"https://platform.openai.com/docs/guides/text-generation"}],"test":{"id":"content-p1-s5-test","title":"Video Scripting with AI Check","questions":[{"id":"content-p1-s5-q1","question":"In Video Scripting with AI, which option is the correct technical choice?","options":["Unstructured guessing without validation","Script beats with hook, value sequence, and CTA","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"Script beats with hook, value sequence, and CTA is the professional technique for this topic."},{"id":"content-p1-s5-q2","question":"A workflow for Video Scripting with AI fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["Script beats with hook, value sequence, and CTA","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"Script beats with hook, value sequence, and CTA is the professional technique for this topic."},{"id":"content-p1-s5-q3","question":"Which review check best confirms Video Scripting with AI is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}}],"finalTest":{"id":"acc-p1-final","title":"Phase 1 Final: AI Content Creator Foundations","questions":[{"id":"acc-p1-final-q1","question":"In AI Content Creator Foundations, what should be defined before a workflow, prompt, model, or dashboard is released?","options":["Only the tool brand used in the demo","Input data, output format, acceptance criteria, owner, and validation method","A promise that the AI will never make mistakes","The color of the final presentation"],"correctAnswerIndex":1,"explanation":"A professional release needs defined inputs, outputs, owners, validation, and acceptance criteria."},{"id":"acc-p1-final-q2","question":"Which signal indicates a quality problem during AI Content Creator Foundations?","options":["The workflow includes source links and logs","Outputs are confident but cannot be traced to source data, rules, or tests","The project has a rollback or revision plan","The team records assumptions and constraints"],"correctAnswerIndex":1,"explanation":"Confident untraceable outputs are a core risk in AI-enabled work."},{"id":"acc-p1-final-q3","question":"Which artifact best supports maintenance after AI Content Creator Foundations is handed off?","options":["A private chat message with no context","A runbook or case study with data sources, configuration, tests, and known limitations","A screenshot of the final result only","An undocumented copy of the prompt or workflow"],"correctAnswerIndex":1,"explanation":"Maintenance requires documented sources, configuration, tests, limitations, and ownership."},{"id":"acc-p1-final-q4","question":"When a result from AI Content Creator Foundations affects customers or business decisions, what should happen before it is trusted?","options":["It should be reviewed against source evidence and domain rules","It should be accepted because it was generated quickly","It should be hidden from stakeholders","It should be reformatted without checking substance"],"correctAnswerIndex":0,"explanation":"Customer-facing and decision-support outputs need evidence checks and domain review."},{"id":"acc-p1-final-q5","question":"Which metric or check is most useful for proving AI Content Creator Foundations created value?","options":["Number of tools mentioned in the project","Measured accuracy, time saved, risk reduced, revenue impact, or stakeholder task success","Whether the demo used the newest AI model","Number of colors used in the interface"],"correctAnswerIndex":1,"explanation":"Professional AI work should connect technical output to measurable quality, efficiency, risk, or business value."}]}},{"id":"acc-p2","phaseNumber":2,"title":"SEO Content Production","description":"Build professional skill in seo content production with real tools, standards, and deliverables.","estimatedDuration":"2 weeks","weekRange":"Week 3-4","outcome":"You can apply seo content production in portfolio-grade work.","access":"locked","sections":[{"id":"acc-p2-s1","title":"SEO Content Production: Core Workflow","description":"Practice the core w