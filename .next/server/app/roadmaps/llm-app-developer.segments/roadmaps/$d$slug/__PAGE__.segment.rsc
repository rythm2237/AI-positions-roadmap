0:{"rsc":["$","$1","c",{"children":[["$","$L2",null,{"roadmap":{"id":"8","slug":"llm-app-developer","title":"LLM Application Developer","description":"Build retrieval, tool-use, structured-output, and production-ready applications on top of language models.","category":"Development","level":"Intermediate","duration":"12 weeks","status":"mvp-ready","totalEstimatedHours":66,"phases":[{"id":"lad-p1","phaseNumber":1,"title":"LLM Application Developer Foundations","description":"Learn the core concepts, tools, and safety checks for llm application developer.","estimatedDuration":"2 weeks","weekRange":"Week 1-2","outcome":"You can complete a practical first workflow for llm application developer.","access":"free","sections":[{"id":"llm-p1-s1","title":"LLM API Fundamentals","description":"Call text-generation APIs, handle model parameters, tokens, and errors.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"OpenAI Text Generation Guide","type":"article","url":"https://platform.openai.com/docs/guides/text-generation"},{"label":"Anthropic Messages API","type":"article","url":"https://docs.anthropic.com/en/api/messages"}],"test":{"id":"llm-p1-s1-test","title":"LLM API Fundamentals Check","questions":[{"id":"llm-p1-s1-q1","question":"In LLM API Fundamentals, which option is the correct technical choice?","options":["Unstructured guessing without validation","API calls with token, latency, and error handling","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"API calls with token, latency, and error handling is the professional technique for this topic."},{"id":"llm-p1-s1-q2","question":"A workflow for LLM API Fundamentals fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["API calls with token, latency, and error handling","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"API calls with token, latency, and error handling is the professional technique for this topic."},{"id":"llm-p1-s1-q3","question":"Which review check best confirms LLM API Fundamentals is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"llm-p1-s2","title":"Structured Outputs","description":"Return typed JSON for downstream code and automation.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"OpenAI Structured Outputs","type":"article","url":"https://platform.openai.com/docs/guides/structured-outputs"},{"label":"Instructor Library","type":"tool","url":"https://github.com/instructor-ai/instructor"}],"test":{"id":"llm-p1-s2-test","title":"Structured Outputs Check","questions":[{"id":"llm-p1-s2-q1","question":"In Structured Outputs, which option is the correct technical choice?","options":["Unstructured guessing without validation","Schema-constrained structured output validated by code","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"Schema-constrained structured output validated by code is the professional technique for this topic."},{"id":"llm-p1-s2-q2","question":"A workflow for Structured Outputs fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["Schema-constrained structured output validated by code","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"Schema-constrained structured output validated by code is the professional technique for this topic."},{"id":"llm-p1-s2-q3","question":"Which review check best confirms Structured Outputs is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"llm-p1-s3","title":"RAG Concepts","description":"Understand embeddings, chunking, vector search, and grounded generation.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"LangChain RAG Tutorial","type":"article","url":"https://js.langchain.com/docs/tutorials/rag/"},{"label":"Pinecone Learn","type":"article","url":"https://www.pinecone.io/learn/"}],"test":{"id":"llm-p1-s3-test","title":"RAG Concepts Check","questions":[{"id":"llm-p1-s3-q1","question":"In RAG Concepts, which option is the correct technical choice?","options":["Unstructured guessing without validation","Retrieval augmented generation with source-grounded context","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"Retrieval augmented generation with source-grounded context is the professional technique for this topic."},{"id":"llm-p1-s3-q2","question":"A workflow for RAG Concepts fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["Retrieval augmented generation with source-grounded context","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"Retrieval augmented generation with source-grounded context is the professional technique for this topic."},{"id":"llm-p1-s3-q3","question":"Which review check best confirms RAG Concepts is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"llm-p1-s4","title":"Prompt and Response Evaluation","description":"Measure answer quality, faithfulness, and regression risk.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"LangSmith Docs","type":"tool","url":"https://docs.smith.langchain.com/"},{"label":"Stanford HELM","type":"article","url":"https://crfm.stanford.edu/helm/latest/"}],"test":{"id":"llm-p1-s4-test","title":"Prompt and Response Evaluation Check","questions":[{"id":"llm-p1-s4-q1","question":"In Prompt and Response Evaluation, which option is the correct technical choice?","options":["Unstructured guessing without validation","Eval set with expected behavior and failure cases","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"Eval set with expected behavior and failure cases is the professional technique for this topic."},{"id":"llm-p1-s4-q2","question":"A workflow for Prompt and Response Evaluation fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["Eval set with expected behavior and failure cases","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"Eval set with expected behavior and failure cases is the professional technique for this topic."},{"id":"llm-p1-s4-q3","question":"Which review check best confirms Prompt and Response Evaluation is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"llm-p1-s5","title":"App Safety and Guardrails","description":"Apply policy checks, refusal paths, rate limits, and logging.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"OpenAI Usage Policies","type":"article","url":"https://openai.com/policies/usage-policies/"},{"label":"NIST AI RMF","type":"article","url":"https://www.nist.gov/itl/ai-risk-management-framework"}],"test":{"id":"llm-p1-s5-test","title":"App Safety and Guardrails Check","questions":[{"id":"llm-p1-s5-q1","question":"In App Safety and Guardrails, which option is the correct technical choice?","options":["Unstructured guessing without validation","Guardrails for unsafe inputs, PII, and ungrounded answers","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"Guardrails for unsafe inputs, PII, and ungrounded answers is the professional technique for this topic."},{"id":"llm-p1-s5-q2","question":"A workflow for App Safety and Guardrails fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["Guardrails for unsafe inputs, PII, and ungrounded answers","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"Guardrails for unsafe inputs, PII, and ungrounded answers is the professional technique for this topic."},{"id":"llm-p1-s5-q3","question":"Which review check best confirms App Safety and Guardrails is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}}],"finalTest":{"id":"lad-p1-final","title":"Phase 1 Final: LLM Application Developer Foundations","questions":[{"id":"lad-p1-final-q1","question":"In LLM Application Developer Foundations, what should be defined before a workflow, prompt, model, or dashboard is released?","options":["Only the tool brand used in the demo","Input data, output format, acceptance criteria, owner, and validation method","A promise that the AI will never make mistakes","The color of the final presentation"],"correctAnswerIndex":1,"explanation":"A professional release needs defined inputs, outputs, owners, validation, and acceptance criteria."},{"id":"lad-p1-final-q2","question":"Which signal indicates a quality problem during LLM Application Developer Foundations?","options":["The workflow includes source links and logs","Outputs are confident but cannot be traced to source data, rules, or tests","The project has a rollback or revision plan","The team records assumptions and constraints"],"correctAnswerIndex":1,"explanation":"Confident untraceable outputs are a core risk in AI-enabled work."},{"id":"lad-p1-final-q3","question":"Which artifact best supports maintenance after LLM Application Developer Foundations is handed off?","options":["A private chat message with no context","A runbook or case study with data sources, configuration, tests, and known limitations","A screenshot of the final result only","An undocumented copy of the prompt or workflow"],"correctAnswerIndex":1,"explanation":"Maintenance requires documented sources, configuration, tests, limitations, and ownership."},{"id":"lad-p1-final-q4","question":"When a result from LLM Application Developer Foundations affects customers or business decisions, what should happen before it is trusted?","options":["It should be reviewed against source evidence and domain rules","It should be accepted because it was generated quickly","It should be hidden from stakeholders","It should be reformatted without checking substance"],"correctAnswerIndex":0,"explanation":"Customer-facing and decision-support outputs need evidence checks and domain review."},{"id":"lad-p1-final-q5","question":"Which metric or check is most useful for proving LLM Application Developer Foundations created value?","options":["Number of tools mentioned in the project","Measured accuracy, time saved, risk reduced, revenue impact, or stakeholder task success","Whether the demo used the newest AI model","Number of colors used in the interface"],"correctAnswerIndex":1,"explanation":"Professional AI work should connect technical output to measurable quality, efficiency, risk, or business value."}]}},{"id":"lad-p2","phaseNumber":2,"title":"LangChain Application Patterns","description":"Build professional skill in langchain application patterns with real tools, standards, and deliverables.","estimatedDuration":"2 weeks","weekRange":"Week 3-4","outcome":"You can apply langchain application patterns in portfolio-grade work.","access":"locked","sections":[{"id":"lad-p2-s1","title":"LangChain Application Patterns: Core Workflow","description":"Practice the core workflow for langchain application patterns.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"LangChain RAG Tutorial","type":"article","url":"https://js.langchain.com/docs/tutorials/rag/"},{"label":"Hugging Face NLP Course","type":"article","url":"https://huggingface.co/learn/nlp-course/chapter1/1"}],"test":{"id"