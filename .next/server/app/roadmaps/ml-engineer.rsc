4:["$","$Lf",null,{"roadmap":{"id":"5","slug":"ml-engineer","title":"Machine Learning Engineer","description":"Build, evaluate, deploy, and monitor machine-learning models with Python, scikit-learn, PyTorch, and MLOps practices.","category":"Machine Learning","level":"Intermediate","duration":"12 weeks","status":"mvp-ready","totalEstimatedHours":66,"phases":[{"id":"me-p1","phaseNumber":1,"title":"Machine Learning Engineer Foundations","description":"Learn the core concepts, tools, and safety checks for machine learning engineer.","estimatedDuration":"2 weeks","weekRange":"Week 1-2","outcome":"You can complete a practical first workflow for machine learning engineer.","access":"free","sections":[{"id":"ml-p1-s1","title":"Python and Notebooks for ML","description":"Set up reproducible notebooks and Python environments.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"Kaggle Python Course","type":"practice","url":"https://www.kaggle.com/learn/python"},{"label":"Google Colab Intro","type":"tool","url":"https://colab.research.google.com/notebooks/intro.ipynb"}],"test":{"id":"ml-p1-s1-test","title":"Python and Notebooks for ML Check","questions":[{"id":"ml-p1-s1-q1","question":"In Python and Notebooks for ML, which option is the correct technical choice?","options":["Unstructured guessing without validation","Reproducible notebook with dependencies and fixed random seeds","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"Reproducible notebook with dependencies and fixed random seeds is the professional technique for this topic."},{"id":"ml-p1-s1-q2","question":"A workflow for Python and Notebooks for ML fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["Reproducible notebook with dependencies and fixed random seeds","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"Reproducible notebook with dependencies and fixed random seeds is the professional technique for this topic."},{"id":"ml-p1-s1-q3","question":"Which review check best confirms Python and Notebooks for ML is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"ml-p1-s2","title":"Supervised Learning Basics","description":"Understand features, labels, train/test splits, and baseline models.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"Kaggle Intro to ML","type":"practice","url":"https://www.kaggle.com/learn/intro-to-machine-learning"},{"label":"scikit-learn Tutorial","type":"article","url":"https://scikit-learn.org/stable/tutorial/basic/tutorial.html"}],"test":{"id":"ml-p1-s2-test","title":"Supervised Learning Basics Check","questions":[{"id":"ml-p1-s2-q1","question":"In Supervised Learning Basics, which option is the correct technical choice?","options":["Unstructured guessing without validation","Train/validation split with baseline model performance","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"Train/validation split with baseline model performance is the professional technique for this topic."},{"id":"ml-p1-s2-q2","question":"A workflow for Supervised Learning Basics fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["Train/validation split with baseline model performance","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"Train/validation split with baseline model performance is the professional technique for this topic."},{"id":"ml-p1-s2-q3","question":"Which review check best confirms Supervised Learning Basics is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"ml-p1-s3","title":"Model Evaluation Metrics","description":"Choose accuracy, precision, recall, F1, ROC-AUC, or RMSE based on task.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"scikit-learn Tutorial","type":"article","url":"https://scikit-learn.org/stable/tutorial/basic/tutorial.html"},{"label":"Kaggle Intro to ML","type":"practice","url":"https://www.kaggle.com/learn/intro-to-machine-learning"}],"test":{"id":"ml-p1-s3-test","title":"Model Evaluation Metrics Check","questions":[{"id":"ml-p1-s3-q1","question":"In Model Evaluation Metrics, which option is the correct technical choice?","options":["Unstructured guessing without validation","Metric selected according to business cost of errors","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"Metric selected according to business cost of errors is the professional technique for this topic."},{"id":"ml-p1-s3-q2","question":"A workflow for Model Evaluation Metrics fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["Metric selected according to business cost of errors","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"Metric selected according to business cost of errors is the professional technique for this topic."},{"id":"ml-p1-s3-q3","question":"Which review check best confirms Model Evaluation Metrics is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"ml-p1-s4","title":"Neural Network Foundations","description":"Learn tensors, gradients, loss functions, and training loops.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"PyTorch Basics","type":"practice","url":"https://pytorch.org/tutorials/beginner/basics/intro.html"},{"label":"fast.ai Course","type":"video","url":"https://course.fast.ai/"}],"test":{"id":"ml-p1-s4-test","title":"Neural Network Foundations Check","questions":[{"id":"ml-p1-s4-q1","question":"In Neural Network Foundations, which option is the correct technical choice?","options":["Unstructured guessing without validation","Loss function and gradient-based optimization","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"Loss function and gradient-based optimization is the professional technique for this topic."},{"id":"ml-p1-s4-q2","question":"A workflow for Neural Network Foundations fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["Loss function and gradient-based optimization","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"Loss function and gradient-based optimization is the professional technique for this topic."},{"id":"ml-p1-s4-q3","question":"Which review check best confirms Neural Network Foundations is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"ml-p1-s5","title":"Data Leakage and Validation","description":"Prevent target leakage and build reliable validation schemes.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"Kaggle Data Cleaning","type":"practice","url":"https://www.kaggle.com/learn/data-cleaning"},{"label":"scikit-learn Tutorial","type":"article","url":"https://scikit-learn.org/stable/tutorial/basic/tutorial.html"}],"test":{"id":"ml-p1-s5-test","title":"Data Leakage and Validation Check","questions":[{"id":"ml-p1-s5-q1","question":"In Data Leakage and Validation, which option is the correct technical choice?","options":["Unstructured guessing without validation","Leakage checks before reporting model performance","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"Leakage checks before reporting model performance is the professional technique for this topic."},{"id":"ml-p1-s5-q2","question":"A workflow for Data Leakage and Validation fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["Leakage checks before reporting model performance","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"Leakage checks before reporting model performance is the professional technique for this topic."},{"id":"ml-p1-s5-q3","question":"Which review check best confirms Data Leakage and Validation is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}}],"finalTest":{"id":"me-p1-final","title":"Phase 1 Final: Machine Learning Engineer Foundations","questions":[{"id":"me-p1-final-q1","question":"In Machine Learning Engineer Foundations, what should be defined before a workflow, prompt, model, or dashboard is released?","options":["Only the tool brand used in the demo","Input data, output format, acceptance criteria, owner, and validation method","A promise that the AI will never make mistakes","The color of the final presentation"],"correctAnswerIndex":1,"explanation":"A professional release needs defined inputs, outputs, owners, validation, and acceptance criteria."},{"id":"me-p1-final-q2","question":"Which signal indicates a quality problem during Machine Learning Engineer Foundations?","options":["The workflow includes source links and logs","Outputs are confident but cannot be traced to source data, rules, or tests","The project has a rollback or revision plan","The team records assumptions and constraints"],"correctAnswerIndex":1,"explanation":"Confident untraceable outputs are a core risk in AI-enabled work."},{"id":"me-p1-final-q3","question":"Which artifact best supports maintenance after Machine Learning Engineer Foundations is handed off?","options":["A private chat message with no context","A runbook or case study with data sources, configuration, tests, and known limitations","A screenshot of the final result only","An undocumented copy of the prompt or workflow"],"correctAnswerIndex":1,"explanation":"Maintenance requires documented sources, configuration, tests, limitations, and ownership."},{"id":"me-p1-final-q4","question":"When a result from Machine Learning Engineer Foundations affects customers or business decisions, what should happen before it is trusted?","options":["It should be reviewed against source evidence and domain rules","It should be accepted because it was generated quickly","It should be hidden from stakeholders","It should be reformatted without checking substance"],"correctAnswerIndex":0,"explanation":"Customer-facing and decision-support outputs need evidence checks and domain review."},{"id":"me-p1-final-q5","question":"Which metric or check is most useful for proving Machine Learning Engineer Foundations created value?","options":["Number of tools mentioned in the project","Measured accuracy, time saved, risk reduced, revenue impact, or stakeholder task success","Whether the demo used the newest AI model","Number of colors used in the interface"],"correctAnswerIndex":1,"explanation":"Professional AI work should connect technical output to measurable quality, efficiency, risk, or business value."}]}},{"id":"me-p2","phaseNumber":2,"title":"scikit-learn Model Building","description":"Build professional skill in scikit-learn model building with real tools, standards, and deliverables.","estimatedDuration":"2 weeks","weekRange":"Week 3-4","outcome":"You can apply scikit-learn model building in portfolio-grade work.","access":"locked","sections":[{"id":"me-p2-s1","title":"scikit-learn Model Building: Core Workflow","description":"Practice the core workflow for scikit-learn model building.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"scikit-learn Tutorial","type":"article","url":"https://scikit-learn.org/stable/tutorial/basic/tutorial.html"},{"label":"MLOps Zoo