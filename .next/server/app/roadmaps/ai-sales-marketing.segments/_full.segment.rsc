4:["$","$Lf",null,{"roadmap":{"id":"10","slug":"ai-sales-marketing","title":"AI Sales & Marketing Specialist","description":"Use AI to improve CRM workflows, personalization, campaign creation, forecasting, and revenue operations.","category":"Sales & Marketing","level":"Beginner to Intermediate","duration":"12 weeks","status":"mvp-ready","totalEstimatedHours":66,"phases":[{"id":"asm-p1","phaseNumber":1,"title":"AI Sales & Marketing Specialist Foundations","description":"Learn the core concepts, tools, and safety checks for ai sales & marketing specialist.","estimatedDuration":"2 weeks","weekRange":"Week 1-2","outcome":"You can complete a practical first workflow for ai sales & marketing specialist.","access":"free","sections":[{"id":"sales-p1-s1","title":"AI CRM Workflow Basics","description":"Use AI to summarize leads, enrich CRM records, and prioritize follow-up.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"Salesforce AI","type":"article","url":"https://www.salesforce.com/artificial-intelligence/"},{"label":"HubSpot AI Sales Guide","type":"article","url":"https://blog.hubspot.com/sales/ai-sales"}],"test":{"id":"sales-p1-s1-test","title":"AI CRM Workflow Basics Check","questions":[{"id":"sales-p1-s1-q1","question":"In AI CRM Workflow Basics, which option is the correct technical choice?","options":["Unstructured guessing without validation","CRM workflow with validated enrichment and next-best action","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"CRM workflow with validated enrichment and next-best action is the professional technique for this topic."},{"id":"sales-p1-s1-q2","question":"A workflow for AI CRM Workflow Basics fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["CRM workflow with validated enrichment and next-best action","Unstructured guessing without validation","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":0,"explanation":"CRM workflow with validated enrichment and next-best action is the professional technique for this topic."},{"id":"sales-p1-s1-q3","question":"Which review check best confirms AI CRM Workflow Basics is ready for a client or stakeholder?","options":["Only checking whether the output looks impressive","Verifying the output against source data, constraints, and acceptance criteria","Removing all logs after a successful demo","Using the same prompt or workflow for every domain"],"correctAnswerIndex":1,"explanation":"Professional AI work needs verification against source data, constraints, and acceptance criteria before handoff."}]}},{"id":"sales-p1-s2","title":"Personalisation at Scale","description":"Segment audiences and generate tailored messaging with review controls.","estimatedTime":"3 hours","difficulty":"Beginner","learningTypes":["Reading","Practice"],"resources":[{"label":"HubSpot AI Sales Guide","type":"article","url":"https://blog.hubspot.com/sales/ai-sales"},{"label":"OpenAI Prompt Engineering Guide","type":"article","url":"https://platform.openai.com/docs/guides/prompt-engineering"}],"test":{"id":"sales-p1-s2-test","title":"Personalisation at Scale Check","questions":[{"id":"sales-p1-s2-q1","question":"In Personalisation at Scale, which option is the correct technical choice?","options":["Unstructured guessing without validation","Segment-specific messaging based on verified attributes","Publishing output without review","Skipping source constraints"],"correctAnswerIndex":1,"explanation":"Segment-specific messaging based on verified attributes is the professional technique for this topic."},{"id":"sales-p1-s2-q2","question":"A workflow for Personalisation at Scale fails because the team used \"Unstructured guessing without validation\". What should they use instead?","options":["Segment-specific messaging based on verified attributes","Unstructured gues